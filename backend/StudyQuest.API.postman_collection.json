{
	"info": {
		"_postman_id": "study-quest-api-collection",
		"name": "Study Quest API",
		"description": "Complete Postman collection for the Study Quest API.\n\n## Setup\n1. Register or login to get an access token\n2. The token is automatically saved to the `accessToken` collection variable\n3. All authenticated endpoints use the Bearer token from that variable\n\n## Variables\n- `baseUrl` — API base URL (default: `http://localhost:5197`)\n- `accessToken` — JWT access token (auto-set on login/register)\n- `refreshToken` — Refresh token (auto-set on login/register)\n- `subjectId`, `topicId`, `enrollmentId`, `planId`, `itemId`, `entryId`, `reminderId` — Entity IDs populated by create requests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5197",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "subjectId",
			"value": "",
			"type": "string"
		},
		{
			"key": "topicId",
			"value": "",
			"type": "string"
		},
		{
			"key": "enrollmentId",
			"value": "",
			"type": "string"
		},
		{
			"key": "planId",
			"value": "",
			"type": "string"
		},
		{
			"key": "itemId",
			"value": "",
			"type": "string"
		},
		{
			"key": "entryId",
			"value": "",
			"type": "string"
		},
		{
			"key": "reminderId",
			"value": "",
			"type": "string"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string"
		},
		{
			"key": "phoneNumber",
			"value": "+221770000000",
			"type": "string"
		},
