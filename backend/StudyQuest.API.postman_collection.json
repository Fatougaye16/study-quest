	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints — register, login, OTP, token refresh, logout.",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', json.accessToken);",
									"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"    pm.test('Register successful', function () {",
									"        pm.expect(json).to.have.property('accessToken');",
									"        pm.expect(json).to.have.property('student');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"password\": \"{{password}}\",\n  \"firstName\": \"Fatou\",\n  \"lastName\": \"Gaye\",\n  \"grade\": 10,\n  \"enableOtp\": false\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Register a new student. Password must be at least 8 characters with at least 1 letter and 1 digit. Set enableOtp to true to require OTP verification on every login. Returns JWT tokens."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.otpRequired) {",
									"        pm.test('OTP required for login', function () {",
									"            pm.expect(json.otpRequired).to.be.true;",
									"            pm.expect(json).to.have.property('phoneNumber');",
									"        });",
									"    } else {",
									"        pm.collectionVariables.set('accessToken', json.accessToken);",
									"        pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"        pm.test('Login successful', function () {",
									"            pm.expect(json).to.have.property('accessToken');",
									"            pm.expect(json).to.have.property('student');",
									"        });",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"password\": \"{{password}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login with phone number and password. If OTP is enabled on the account, returns { otpRequired: true, phoneNumber } instead of tokens — call request-otp then verify-otp to complete login."
					},
					"response": []
				},
				{
					"name": "Request OTP",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/request-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "request-otp"]
						},
						"description": "Request a 6-digit OTP via SMS. Rate limited to 3 requests per 10 minutes per phone number. OTP valid for 5 minutes. In Development mode, OTP is logged to console."
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', json.accessToken);",
									"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"    pm.test('OTP verified', function () {",
									"        pm.expect(json).to.have.property('accessToken');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"otpCode\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "verify-otp"]
						},
						"description": "Verify a 6-digit OTP code. Creates account if phone number doesn't exist yet. Returns JWT tokens."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', json.accessToken);",
									"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"    pm.test('Token refreshed', function () {",
									"        pm.expect(json).to.have.property('accessToken');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "refresh"]
						},
						"description": "Exchange a refresh token for new access and refresh tokens. Refresh tokens are valid for 30 days."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "logout"]
						},
						"description": "Logout the current user. Invalidates the refresh token. Requires authentication."
					},
					"response": []
				}
			]
		},
